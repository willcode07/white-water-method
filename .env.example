# Copy this file to `.env` and fill in real values for local builds.
# `.env` is read automatically by Create React App at build/start time.
# These values are baked into the production bundle, so don't put real
# secrets here — only public-by-design identifiers like the Cloudinary
# cloud name or the Acuity owner id.

# Cloudinary cloud name. When set, all hero images and assessment videos
# are served from Cloudinary; when empty, the app falls back to local
# files in /public/assessment-videos and Unsplash placeholders for hero
# images. See MEDIA.md for full setup.
REACT_APP_CLOUDINARY_CLOUD=

# Upload script (`npm run upload-media`) — paste the single line from the
# dashboard API Keys section, OR set these three (never commit secrets):
# CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# Optional: bake cloud name into production builds without touching `.env`.
# Create `.env.production` with only REACT_APP_CLOUDINARY_CLOUD — safe to commit.

# Acuity scheduling URL. Optional — falls back to a hard-coded URL in
# CalendlyWidget.js if unset.
REACT_APP_ACUITY_URL=
